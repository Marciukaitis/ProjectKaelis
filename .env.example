# Variables de entorno — Kaelis Atelier
# Copiá este archivo como .env.local para desarrollo.

# ─── Supabase ───────────────────────────────────────────────
# Proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Resend (correos) ───────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_...
# Remitente verificado en Resend (ej: Kaelis Atelier <hola@tudominio.com>)
RESEND_FROM=Kaelis Atelier <onboarding@resend.dev>
# Tu mail donde querés recibir cada cita nueva
NOTIFICATION_EMAIL=tu-email@gmail.com

# ─── Sitio ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Opcional (futuro) ──────────────────────────────────────
# OPENAI_API_KEY=
